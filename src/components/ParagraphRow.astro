---
import { marked } from 'marked';

const { paragraph, allFootnotes } = Astro.props;

// Render markdown inline for paragraph content
let contentHtml = await marked.parseInline(paragraph.content);

// Replace [^N] with linked footnote references that include a hover popup
contentHtml = contentHtml.replace(/\[\^(\d+)\]/g, (match, id) => {
  const fn = allFootnotes.find((f) => f.id == id);
  let popupHtml = '';
  if (fn) {
    // Use marked to render the footnote content, then strip outer <p> if present for compact popup
    const rendered = marked.parseInline(fn.content);
    popupHtml = `<span class="footnote-popup">${rendered}</span>`;
  }
  return `<a href="#footnote-${id}" class="footnote-ref">${match}${popupHtml}</a>`;
});

const hasEnrichment = paragraph.enrichment && typeof paragraph.enrichment === 'string' && paragraph.enrichment.length > 0;
---

<div class="paragraph-row" id={`para-${paragraph.number}`}>
  <div class="paragraph-main">
    <p class="paragraph-text">
      <span class="para-number">{paragraph.number}.</span>
      <span set:html={contentHtml} />
    </p>
  </div>
  <div class="paragraph-enrichment">
    <div class="enrichment-card">
      <div class="enrichment-disclosure ai-disclosure-trigger">
        <svg xmlns="http://www.w3.org/2000/svg" width="0.9em" height="0.9em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-label="AI summary" role="img">
          <path d="M15 19c1.2-3.678 2.526-5.005 6-6c-3.474-.995-4.8-2.322-6-6c-1.2 3.678-2.526 5.005-6 6c3.474.995 4.8 2.322 6 6Zm-8-9c.6-1.84 1.263-2.503 3-3c-1.737-.497-2.4-1.16-3-3c-.6 1.84-1.263 2.503-3 3c1.737.497 2.4 1.16 3 3Zm1.5 10c.3-.92.631-1.251 1.5-1.5c-.869-.249-1.2-.58-1.5-1.5c-.3.92-.631 1.251-1.5 1.5c.869.249 1.2.58 1.5 1.5Z"/>
        </svg>
      </div>
      {hasEnrichment ? (
        <div set:html={marked.parseInline(paragraph.enrichment)} />
      ) : (
        <span class="enrichment-placeholder">Summary will appear here.</span>
      )}
    </div>
  </div>
</div>
