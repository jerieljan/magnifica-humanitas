---
import { getManifest } from '../lib/data.js';

const manifest = getManifest();
const currentPath = Astro.url.pathname;
const currentSlug = currentPath.replace(/^\/|\/index\.html$|\/+$/g, '');
---

<nav class="sidebar-nav">
  <div class="sidebar-header">
    <a href="/">{manifest.meta.title}</a>
    <p>{manifest.meta.subtitle}</p>
  </div>

  <ul>
    {manifest.sections.map((sec) => {
      const isActive = currentSlug === sec.slug;
      return (
        <li>
          <a href={`/${sec.slug}`} class={isActive ? 'active' : ''}>
            {sec.title}
          </a>
          {isActive && sec.subsections && sec.subsections.length > 0 && (
            <ul>
              {sec.subsections.map((sub) => (
                <li class={`subsection ${sub.level === 3 ? 'nested' : ''}`}>
                  <a href={`#${sub.slug}`}>{sub.title}</a>
                </li>
              ))}
            </ul>
          )}
        </li>
      );
    })}
  </ul>

  <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--color-border);">
    <a href="/footnotes" style="font-size: 0.85rem;">All Footnotes</a>
  </div>

  <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border);">
    <a href={manifest.meta.source} target="_blank" rel="noopener noreferrer" style="font-size: 0.85rem;">Source ↗</a>
    <p style="font-size: 0.75rem; color: var(--color-muted); margin-top: 0.25rem;">vatican.va • 15 May 2026</p>
  </div>
</nav>
