---
import '../styles/global.css';
import { getManifest } from '../lib/data.js';
import Sidebar from '../components/Sidebar.astro';

const { title } = Astro.props;
const manifest = getManifest();
const pageTitle = title ? `${title} — ${manifest.meta.title}` : manifest.meta.title;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet">
  <style>
    /* Inline critical layout styles to avoid FOUC */
    .page-container {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 3rem;
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      min-height: 100vh;
    }
    @media (max-width: 1024px) {
      .page-container { grid-template-columns: 1fr; padding: 72px 1rem 1rem; }
    }
  </style>
</head>
<body>
  {/* Mobile Header */}
  <header class="mobile-header" id="mobile-header">
    <button class="mobile-nav-toggle" id="mobile-nav-toggle" aria-label="Open navigation" aria-expanded="false">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
    <span class="mobile-header-title">{manifest.meta.title}</span>
    <button class="mobile-summary-toggle" id="mobile-summary-toggle" aria-label="Show paragraph summary" aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
        <path d="M15 19c1.2-3.678 2.526-5.005 6-6c-3.474-.995-4.8-2.322-6-6c-1.2 3.678-2.526 5.005-6 6c3.474.995 4.8 2.322 6 6Zm-8-9c.6-1.84 1.263-2.503 3-3c-1.737-.497-2.4-1.16-3-3c-.6 1.84-1.263 2.503-3 3c1.737.497 2.4 1.16 3 3Zm1.5 10c.3-.92.631-1.251 1.5-1.5c-.869-.249-1.2-.58-1.5-1.5c-.3.92-.631 1.251-1.5 1.5c.869.249 1.2.58 1.5 1.5Z"/>
      </svg>
    </button>
  </header>

  {/* Mobile Sidebar Overlay */}
  <div class="mobile-sidebar-backdrop" id="mobile-sidebar-backdrop"></div>
  <div class="mobile-sidebar" id="mobile-sidebar">
    <div class="mobile-sidebar-header">
      <button class="mobile-sidebar-close" id="mobile-sidebar-close" aria-label="Close navigation">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <Sidebar />
  </div>

  <div class="page-container">
    <div class="mobile-summary-panel" id="mobile-summary-panel">
      <div id="mobile-summary-content">
        <p class="enrichment-placeholder">Select a paragraph to see its summary.</p>
      </div>
    </div>
    <aside class="sidebar">
      <Sidebar />
    </aside>
    <main class="main-content" id="main-content">
      <slot />
    </main>
  </div>

  <script>
    // Mobile sidebar toggle
    const navToggle = document.getElementById('mobile-nav-toggle');
    const mobileSidebar = document.getElementById('mobile-sidebar');
    const sidebarBackdrop = document.getElementById('mobile-sidebar-backdrop');
    const sidebarClose = document.getElementById('mobile-sidebar-close');
    let sidebarOpen = false;

    function toggleSidebar() {
      sidebarOpen = !sidebarOpen;
      mobileSidebar.classList.toggle('open', sidebarOpen);
      sidebarBackdrop.classList.toggle('open', sidebarOpen);
      navToggle.setAttribute('aria-expanded', String(sidebarOpen));
      if (sidebarOpen) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    }

    navToggle.addEventListener('click', toggleSidebar);
    sidebarBackdrop.addEventListener('click', toggleSidebar);
    sidebarClose.addEventListener('click', toggleSidebar);

    // Close sidebar when a navigation link is clicked
    mobileSidebar.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (sidebarOpen) toggleSidebar();
      });
    });

    // Mobile summary panel toggle
    const summaryToggle = document.getElementById('mobile-summary-toggle');
    const summaryPanel = document.getElementById('mobile-summary-panel');
    let summaryOpen = false;

    function toggleSummary() {
      summaryOpen = !summaryOpen;
      summaryPanel.classList.toggle('open', summaryOpen);
      summaryToggle.classList.toggle('active', summaryOpen);
      summaryToggle.setAttribute('aria-expanded', String(summaryOpen));
    }

    summaryToggle.addEventListener('click', toggleSummary);

    // IntersectionObserver to update active paragraph in scrubber and mobile summary panel
    const observerOptions = { rootMargin: '-20% 0px -60% 0px', threshold: 0 };
    const paragraphs = document.querySelectorAll('.paragraph-row');
    const scrubberLinks = document.querySelectorAll('.paragraph-scrubber .scrubber-link');
    const scrubberProgress = document.getElementById('scrubber-progress');
    const summaryContent = document.getElementById('mobile-summary-content');

    let activeId = null;
    const totalParagraphs = paragraphs.length;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          activeId = entry.target.id;
          const paraNum = parseInt(activeId.replace('para-', ''), 10);

          // Update scrubber active state
          scrubberLinks.forEach((a) => {
            a.classList.toggle('active-para', a.getAttribute('href') === '#' + activeId);
          });

          // Update progress bar
          if (scrubberProgress && totalParagraphs > 0) {
            const progress = ((Array.from(paragraphs).findIndex(p => p.id === activeId) + 1) / totalParagraphs) * 100;
            scrubberProgress.style.width = progress + '%';
          }

          // Scroll active scrubber link into view
          const activeLink = document.querySelector('.paragraph-scrubber .scrubber-link.active-para');
          if (activeLink) {
            activeLink.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
          }

          // Update mobile summary panel
          const enrichment = entry.target.querySelector('.enrichment-card');
          if (summaryContent && enrichment) {
            summaryContent.innerHTML = enrichment.innerHTML;
            const num = entry.target.querySelector('.para-number')?.textContent || '';
            const pre = document.createElement('div');
            pre.style.cssText = 'font-weight:700;color:#2c3e50;margin-bottom:0.5rem;font-size:0.85rem;';
            pre.textContent = 'Paragraph ' + num.replace('.', '');
            summaryContent.prepend(pre);
          }
        }
      });
    }, observerOptions);

    paragraphs.forEach((p) => observer.observe(p));
  </script>
</body>
</html>
