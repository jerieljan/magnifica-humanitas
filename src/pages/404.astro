---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found">
  <div style="text-align: center; padding: 6rem 2rem;">
    <h1 style="font-size: 4rem; margin-bottom: 1rem; color: var(--color-accent);">404</h1>
    <p style="font-size: 1.25rem; color: var(--color-muted); margin-bottom: 2rem;">
      This page could not be found.
    </p>
    <a href="/" style="display: inline-block; padding: 0.75rem 1.5rem; background: var(--color-accent); color: white; border-radius: 6px; text-decoration: none; font-weight: 600;">
      Return Home
    </a>
  </div>
</Layout>
